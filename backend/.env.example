# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/football_tracker?schema=public"

# JWT
JWT_SECRET="a-long-random-secret"
JWT_EXPIRES_IN="7d"

# football-data.org API token (https://www.football-data.org/client/register)
FOOTBALL_DATA_KEY="your_football_data_org_token"

# API-Football on RapidAPI (https://rapidapi.com/api-sports/api/api-football) — used
# only for match lineups/events/statistics and player stats (football-data.org lacks these).
APIFOOTBALL_KEY="your_rapidapi_key"
APIFOOTBALL_HOST="api-football-v1.p.rapidapi.com"

# Server
PORT=4000

# CORS: the frontend origin allowed to call this API
CLIENT_ORIGIN="http://localhost:5173"
